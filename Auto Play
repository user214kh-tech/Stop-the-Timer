        alarmSet = false; alarmTriggered = false; alarmHour = nil; alarmMin = nil
        setAlarmBtn.Text = "⏰ Set Time Alarm"
        setAlarmBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        timeAlarmStatus.Text = "Alarm cancelled"
        timeAlarmStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        unlockTimeInputs()
    else
        alarmSet = true
        local h = currentHour
        if currentAmPm == "PM" and h ~= 12 then h = h + 12 end
        if currentAmPm == "AM" and h == 12 then h = 0 end
        alarmHour = h; alarmMin = currentMin
        setAlarmBtn.Text = "❌ Cancel Time Alarm"
        setAlarmBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
        timeAlarmStatus.Text = string.format("Alarm: %d:%02d %s", currentHour, currentMin, currentAmPm)
        timeAlarmStatus.TextColor3 = Color3.fromRGB(150, 255, 150)
        lockTimeInputs()
    end
end)

