-- Internal values
local currentHour = 12
local currentMin = 0
local currentAmPm = "AM"
local currentStreakTarget = 50

local function initializeDefaults()
    local t = os.date("*t")
    currentHour = t.hour % 12
    if currentHour == 0 then currentHour = 12 end
    currentMin = t.min
    currentAmPm = t.hour >= 12 and "PM" or "AM"
    currentStreakTarget = getStreak()
    hourLabel.Text = tostring(currentHour)
    minLabel.Text = string.format("%02d", currentMin)
    ampmBtn.Text = currentAmPm
    streakValueLabel.Text = "🔥 " .. currentStreakTarget
    if currentAmPm == "PM" then
        ampmBtn.BackgroundColor3 = Color3.fromRGB(180, 80, 50)
    end
end
initializeDefaults()

local function lockTimeInputs()
    hourUp.Interactable = false; hourUp.BackgroundColor3 = Color3.fromRGB(40,40,50); hourUp.TextColor3 = Color3.fromRGB(120,120,120)
    hourDown.Interactable = false; hourDown.BackgroundColor3 = Color3.fromRGB(40,40,50); hourDown.TextColor3 = Color3.fromRGB(120,120,120)
    minUp.Interactable = false; minUp.BackgroundColor3 = Color3.fromRGB(40,40,50); minUp.TextColor3 = Color3.fromRGB(120,120,120)
    minDown.Interactable = false; minDown.BackgroundColor3 = Color3.fromRGB(40,40,50); minDown.TextColor3 = Color3.fromRGB(120,120,120)
    ampmBtn.Interactable = false; ampmBtn.BackgroundColor3 = Color3.fromRGB(40,40,50); ampmBtn.TextColor3 = Color3.fromRGB(120,120,120)
end
local function unlockTimeInputs()
    hourUp.Interactable = true; hourUp.BackgroundColor3 = Color3.fromRGB(50,50,90); hourUp.TextColor3 = Color3.fromRGB(255,255,255)
    hourDown.Interactable = true; hourDown.BackgroundColor3 = Color3.fromRGB(50,50,90); hourDown.TextColor3 = Color3.fromRGB(255,255,255)
    minUp.Interactable = true; minUp.BackgroundColor3 = Color3.fromRGB(50,50,90); minUp.TextColor3 = Color3.fromRGB(255,255,255)
    minDown.Interactable = true; minDown.BackgroundColor3 = Color3.fromRGB(50,50,90); minDown.TextColor3 = Color3.fromRGB(255,255,255)
    ampmBtn.Interactable = true
    ampmBtn.BackgroundColor3 = currentAmPm == "PM" and Color3.fromRGB(180,80,50) or Color3.fromRGB(50,50,90)
    ampmBtn.TextColor3 = Color3.fromRGB(255,255,255)
end
