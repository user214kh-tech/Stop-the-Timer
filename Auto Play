local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local localPlayer = Players.LocalPlayer

local AUTO_STOP_ENABLED = true
local OFFSET = -0.15   -- ← Tune this (more negative = click earlier)

local function getMyButton()
    local char = localPlayer.Character
    if not char then return nil end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name == "Button" and v:IsA("BasePart") then
            local seat = v:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Seat", true)
            if seat and seat.Occupant and seat.Occupant.Parent == char then
                return v
            end
        end
    end
    return nil
end

local function clickButton()
    local button = getMyButton()
    if button then
        local cd = button:FindFirstChildOfClass("ClickDetector")
        if cd then
            cd:Invoke()
            return true
        end
    end
    return false
end

local function getTargetTime()
    local ui = localPlayer:FindFirstChild("PlayerGui")?.GameUI
    if not ui then return nil end
    local sec = ui:FindFirstChild("SecondsToSet")
    if not sec or not sec.Visible then return nil end
    return tonumber((sec.Text or ""):match("(%d+%.%d+)"))
end

local function isMyTurn()
    local ui = localPlayer:FindFirstChild("PlayerGui")?.GameUI
    if not ui then return false end
    local sec = ui:FindFirstChild("SecondsToSet")
    local turn = sec and sec:FindFirstChild("TurnText")
    return turn and turn.Text == "Your Turn"
end

RunService.Heartbeat:Connect(function()
    local target = getTargetTime()
    if not target then return end

    if AUTO_STOP_ENABLED and isMyTurn() then
        local now = Workspace:GetServerTimeNow()
        if now >= (target + OFFSET) then
            clickButton()
        end
    end
end)

print("Auto Stop Script Loaded | Offset: " .. OFFSET)
