playButton.MouseButton1Click:Connect(function()
    autoPlayEnabled = not autoPlayEnabled
    playButton.Text = autoPlayEnabled and "🤖 Auto AI Play: ON" or "🤖 Auto AI Play: OFF"
    playButton.BackgroundColor3 = autoPlayEnabled and Color3.fromRGB(50,180,50) or Color3.fromRGB(180,50,50)
    if not autoPlayEnabled then clicked = false end
end)

-- Drag
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Main Loop
local clockTick = 0
RunService.Heartbeat:Connect(function(dt)
    if autoSeatEnabled then
        local character = localPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if humanoid and rootPart then
                local targetSeat = getTargetSeat()
                if targetSeat and targetSeat:IsA("Seat") then
                    if humanoid.SeatPart ~= targetSeat then
                        if targetSeat.Occupant and targetSeat.Occupant ~= humanoid then
                            seatButton.Text = "🪑 Seat Occupied!"
                        else
                            seatButton.Text = "🪑 Auto Seat: ON"
                            rootPart.CFrame = targetSeat.CFrame
                            targetSeat:Sit(humanoid)
                        end
                    end
                end
            end
        end
    end

    if autoPlayEnabled then
        local playerGui = localPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local gameUI = playerGui:FindFirstChild("GameUI")
            if gameUI then
                local aiPrompt = gameUI:FindFirstChild("AIPrompt")
                if aiPrompt then
                    local playBtn = aiPrompt:FindFirstChild("Play")
                    if playBtn and aiPrompt.Visible and playBtn.Visible and not clicked then
                        clicked = true
                        task.spawn(function()
                            task.wait(0.3)
                            local pos = playBtn.AbsolutePosition
                            local size = playBtn.AbsoluteSize
                            local centerX = math.floor(pos.X + size.X / 2) + 40
                            local centerY = math.floor(pos.Y + size.Y / 2) + 50
                            mouse1press(centerX, centerY)
                            task.wait(0.1)
                            mouse1release(centerX, centerY)
                            task.wait(1)
                            clicked = false
                        end)
                    elseif not aiPrompt.Visible then
                        clicked = false
                    end
                end
            end
        end
    end

    clockTick = clockTick + dt
    if clockTick >= 1 then
        clockTick = 0
        local t = os.date("*t")
        local hour = t.hour; local min = t.min; local ampm = "AM"
        if hour >= 12 then ampm = "PM"; if hour > 12 then hour = hour - 12 end end
        if hour == 0 then hour = 12 end
        clockLabel.Text = string.format("🕐 %d:%02d %s", hour, min, ampm)

        local currentStreak = getStreak()
        streakDisplay.Text = "🔥 Streak: " .. currentStreak

        if streakAlarmSet and streakTarget and streakTarget > 1 then
            if currentStreak >= (streakTarget - 1) then
                autoSeatEnabled = false
                seatButton.Text = "🪑 Auto Seat: OFF (Last Round)"
                seatButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
            end
        end

        if alarmSet and alarmHour ~= nil and alarmMin ~= nil then
            if t.hour == alarmHour and t.min == alarmMin then
                alarmSet = false; alarmTriggered = true
                autoSeatEnabled = false
                seatButton.Text = "🪑 Auto Seat: OFF"
                seatButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                setAlarmBtn.Text = "❌ Cancel Time Alarm"
                timeAlarmStatus.Text = "⏳ Waiting for round to end..."
                timeAlarmStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
            end
        end

        if streakAlarmSet and streakTarget ~= nil then
            if currentStreak >= streakTarget then
                streakAlarmSet = false; streakAlarmTriggered = true
                autoSeatEnabled = false
                seatButton.Text = "🪑 Auto Seat: OFF"
                seatButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                setStreakAlarmBtn.Text = "❌ Cancel Streak Alarm"
                streakAlarmStatus.Text = "⏳ Waiting for round to end..."
                streakAlarmStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
            end
        end

        if alarmTriggered then
            local character = localPlayer.Character
            if character then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.SeatPart == nil then
                    localPlayer:Kick("⏰ Time alarm - time to stop playing!")
                end
            end
        end

        if streakAlarmTriggered then
            local character = localPlayer.Character
            if character then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.SeatPart == nil then
                    localPlayer:Kick("🔥 Streak goal reached - time to stop!")
                end
            end
        end
    end
end)

