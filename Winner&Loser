-- ==========================================
-- 1. DETECT THE EXACT CHAIR AND STATION NUMBER
-- ==========================================
local function updateCurrentSeatLocation()
    local character = localPlayer.Character
    if not character then 
        currentStationFolder = nil
        currentStationName = "No Character Found"
        return 
    end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or not humanoid.SeatPart or not humanoid.SeatPart:IsA("Seat") then
        currentStationName = "Standby (Sit down at a table)"
        return
    end
    
    local mySeat = humanoid.SeatPart
    local gameStations = Workspace:FindFirstChild("GameStations")
    if not gameStations then return end
    
    for _, folder in ipairs({gameStations:FindFirstChild("Normal"), gameStations:FindFirstChild("Hard")}) do
        if folder then
            for _, station in ipairs(folder:GetChildren()) do
                local chairsFolder = station:FindFirstChild("Chairs")
                if chairsFolder then
                    local p1Obj = chairsFolder:FindFirstChild("Player1")
                    if p1Obj and (p1Obj == mySeat or p1Obj:IsAncestorOf(mySeat)) then
                        currentStationFolder = station
                        currentStationName = folder.Name .. " Table " .. station.Name
                        currentSeatRole = "Player1"
                        return
                    end
                    
                    local p2Obj = chairsFolder:FindFirstChild("Player2")
                    if p2Obj and (p2Obj == mySeat or p2Obj:IsAncestorOf(mySeat)) then
                        currentStationFolder = station
                        currentStationName = folder.Name .. " Table " .. station.Name
                        currentSeatRole = "Player2"
                        return
                    end
                end
            end
        end
    end
end

-- ==========================================
-- 2. FETCH LIVE VALUE & GOAL TARGET
-- ==========================================
local function getLiveTableTimerValue()
    if not currentStationFolder then return nil end
    
    local timerModel = currentStationFolder:FindFirstChild("Timer")
    if not timerModel then return nil end
    
    local playerDisplaySide = timerModel:FindFirstChild(currentSeatRole)
    if playerDisplaySide and playerDisplaySide:FindFirstChild("SurfaceGui") then
        local timerTextLabel = playerDisplaySide.SurfaceGui:FindFirstChildOfClass("TextLabel") or playerDisplaySide.SurfaceGui:FindFirstChild("TimerText")
        if timerTextLabel then
            return timerTextLabel.Text
        end
    end
    return nil
end

local function getCleanTargetTime()
    if selectedGameMode == "winner" then
        return "00.50" 
    end

    local gameUi = playerGui:FindFirstChild("GameUI")
    if not gameUi then return nil end
    
    local secondsToSet = gameUi:FindFirstChild("SecondsToSet")
    if secondsToSet and secondsToSet.Visible and secondsToSet.Text ~= "" then
        local targetNum = string.match(secondsToSet.Text, "%d+%.%d+")
        return targetNum
    end
    return nil
end

-- ==========================================
-- 3. AUTO-RESET AND UNSTOPPABLE CLICK ENGINE
-- ==========================================
local function clickPhysicalTableButton()
    if clickingMutex then return end
    clickingMutex = true
    
    task.spawn(function()
        local viewportSize = camera.ViewportSize
        local centerX = math.floor(viewportSize.X / 2)
        local centerY = math.floor(viewportSize.Y / 2)
        
        local adjustedX = centerX + 45
        local adjustedY = centerY + 45
        
        VirtualInputManager:SendMouseButtonEvent(adjustedX, adjustedY, 1, false, game, 0)
        task.wait(0.01)
        
        mouse1press(adjustedX, adjustedY)
        task.wait(0.06)
        mouse1release(adjustedX, adjustedY)
        
        VirtualInputManager:SendMouseButtonEvent(adjustedX, adjustedY, 0, true, game, 0)
        task.wait(0.03)
        VirtualInputManager:SendMouseButtonEvent(adjustedX, adjustedY, 0, false, game, 0)
        
        task.wait(0.5) 
        clickingMutex = false
    end)
end

local function spamClickTableButtonForLoss()
    local viewportSize = camera.ViewportSize
    local centerX = math.floor(viewportSize.X / 2)
    local centerY = math.floor(viewportSize.Y / 2)
    
    local adjustedX = centerX + 45
    local adjustedY = centerY + 45
    
    mouse1press(adjustedX, adjustedY)
    task.wait(0.01)
    mouse1release(adjustedX, adjustedY)
    VirtualInputManager:SendMouseButtonEvent(adjustedX, adjustedY, 0, true, game, 0)
    task.wait(0.01)
    VirtualInputManager:SendMouseButtonEvent(adjustedX, adjustedY, 0, false, game, 0)
end

