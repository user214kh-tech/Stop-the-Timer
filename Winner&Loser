--// =========================================
--// INITIALIZE EVENT LISTENERS FOR JUMPING
--// =========================================
local function hookUIListeners(folder)
	for _, frame in ipairs(folder:GetChildren()) do
		if frame:IsA("GuiObject") then
			frame.Changed:Connect(checkOpponentWinsAndJump)
			frame.ChildAdded:Connect(function(child)
				if child:IsA("GuiObject") then
					child.Changed:Connect(checkOpponentWinsAndJump)
					checkOpponentWinsAndJump()
				end
			end)
			for _, child in ipairs(frame:GetChildren()) do
				if child:IsA("GuiObject") then
					child.Changed:Connect(checkOpponentWinsAndJump)
				end
			end
		end
	end
end

hookUIListeners(roundWins)
roundWins.ChildAdded:Connect(function(child)
	checkOpponentWinsAndJump()
	hookUIListeners(roundWins)
end)

--// =========================================
--// MAIN LOOP
--// =========================================
RunService.Heartbeat:Connect(function()

	-- AUTO SEAT
	if autoSeatEnabled and selectedGameMode ~= "none" then

		local character = localPlayer.Character

		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")

		if humanoid and rootPart then

			local targetSeat = getTargetSeat()

			if targetSeat and targetSeat:IsA("Seat") then

				if humanoid.SeatPart ~= targetSeat then

					if targetSeat.Occupant and targetSeat.Occupant ~= humanoid then

						seatButton.Text = "🪑 Seat Occupied!"

					else

						seatButton.Text = "🪑 Auto Seat: ON"

						rootPart.CFrame = targetSeat.CFrame
						targetSeat:Sit(humanoid)
					end
				end
			end
		end
	end

	updateCurrentSeatLocation()

	local liveTime = getLiveTableTimerValue()
	local targetTime = getCleanTargetTime()

	if liveTime then
		timerLabel.Text = liveTime
	else
		timerLabel.Text = "00.00"
	end

	if liveTime == "00.00"
	or liveTime == "00.01"
	or tonumber(liveTime) == 0
	or not currentStationFolder then

		hasClickedThisRound = false
	end

	if autoClickEnabled and liveTime and liveTime ~= "00.00" then

		if selectedGameMode == "loser" then

			targetLabel.Text = "Mode: FORCED LOSS"

			if not hasClickedThisRound then
				spamClickTableButtonForLoss()
				hasClickedThisRound = true
			end

		elseif selectedGameMode == "winner" and targetTime then

			targetLabel.Text = "Mode: FORCED WIN (00.50)"

			if not hasClickedThisRound and liveTime == targetTime then
				hasClickedThisRound = true
				clickPhysicalTableButton()
			end
		end

	else

		if selectedGameMode == "winner" then
			targetLabel.Text = "Mode: FORCED WIN"
		elseif selectedGameMode == "loser" then
			targetLabel.Text = "Mode: FORCED LOSS"
		else
			targetLabel.Text = "Waiting..."
		end
	end
end)

