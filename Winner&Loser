local function clickPhysicalTableButton()

	if clickingMutex then return end
	clickingMutex = true

	task.spawn(function()

		local viewportSize = camera.ViewportSize

		local centerX = math.floor(viewportSize.X / 2)
		local centerY = math.floor(viewportSize.Y / 2)

		local adjustedX = centerX + 45
		local adjustedY = centerY + 45

		mouse1press(adjustedX, adjustedY)

		task.wait(0.05)

		mouse1release(adjustedX, adjustedY)

		task.wait(0.3)

		clickingMutex = false
	end)
end

local function spamClickTableButtonForLoss()

	local viewportSize = camera.ViewportSize

	local centerX = math.floor(viewportSize.X / 2)
	local centerY = math.floor(viewportSize.Y / 2)

	local adjustedX = centerX + 45
	local adjustedY = centerY + 45

	mouse1press(adjustedX, adjustedY)

	task.wait(0.01)

	mouse1release(adjustedX, adjustedY)
end

--// =========================================
--// INTEGRATED AUTO-JUMP UTILITIES (UPDATED FOR BLUE)
--// =========================================
local function isBlue(color)
	-- Checks if the color has high blue and lower red/green values
	return color.B > 0.8 and color.R < 0.4 and color.G < 0.6
end

local function checkFrameForBlue(frame)
	if not frame:IsA("GuiObject") then return false end
	if isBlue(frame.BackgroundColor3) then return true end
	if frame:IsA("ImageLabel") or frame:IsA("ImageButton") then
		if isBlue(frame.ImageColor3) then return true end
	end
	for _, child in ipairs(frame:GetChildren()) do
		if child:IsA("GuiObject") then
			if isBlue(child.BackgroundColor3) then return true end
			if child:IsA("ImageLabel") or child:IsA("ImageButton") then
				if isBlue(child.ImageColor3) then return true end
			end
			if child:IsA("TextLabel") then
				if isBlue(child.TextColor3) then return true end
			end
		end
	end
	return false
end

local function checkOpponentWinsAndJump()
	local blueWinCount = 0
	
	-- Scan frames '1', '2', '3' from RoundWins UI
	for _, name in ipairs({"1", "2", "3"}) do
		local winFrame = roundWins:FindFirstChild(name)
		if winFrame and checkFrameForBlue(winFrame) then
			blueWinCount = blueWinCount + 1
		end
	end
	
	-- Force a client-side jump to instantly get off the chair if down 2 points to Blue
	if blueWinCount >= 2 then
		local character = localPlayer.Character
		if character then
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid.Jump = true
			end
		end
	end
end

