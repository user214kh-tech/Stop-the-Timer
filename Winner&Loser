-- ==========================================
-- 5. DRAG MECHANICS
-- ==========================================
local dragging, dragStart, startPos

dragBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- ==========================================
-- 6. LIVE VISUAL AVATAR PROFILE & COLOR SYNCER 
--    + NEW: DETECT LOSS COUNT FOR AUTO-LEAVE
-- ==========================================
local function syncRoundWinCircles()
    local gameUi = playerGui:FindFirstChild("GameUI")
    local totalOpponentWins = 0
    
    if gameUi then
        local statusFrame = gameUi:FindFirstChild("StatusFrame")
        if statusFrame then
            local roundWins = statusFrame:FindFirstChild("RoundWins")
            if roundWins then
                for i = 1, 3 do
                    local gameCircle = roundWins:FindFirstChild(tostring(i))
                    local myHudCircle = hudCircles[i]
                    
                    if gameCircle and myHudCircle then
                        if gameCircle:IsA("ImageLabel") then
                            myHudCircle.Image = gameCircle.Image
                            myHudCircle.ImageColor3 = gameCircle.ImageColor3
                            myHudCircle.BackgroundColor3 = gameCircle.BackgroundColor3
                        elseif gameCircle:FindFirstChildOfClass("ImageLabel") then
                            local nestedImage = gameCircle:FindFirstChildOfClass("ImageLabel")
                            myHudCircle.Image = nestedImage.Image
                            myHudCircle.ImageColor3 = nestedImage.ImageColor3
                            myHudCircle.BackgroundColor3 = gameCircle.BackgroundColor3
                        else
                            myHudCircle.BackgroundColor3 = gameCircle.BackgroundColor3
                            myHudCircle.Image = ""
                        end
                        
                        -- Check if opponent won this circle (circle is populated but it's NOT our profile)
                        if gameCircle:IsA("ImageLabel") and gameCircle.Image ~= "" and gameCircle.Image ~= "rbxassetid://0" then
                            local myHeadshot = Players:GetUserThumbnailAsync(localPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
                            if gameCircle.Image ~= myHeadshot then
                                totalOpponentWins = totalOpponentWins + 1
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- NEW AUTO-LEAVE TRIGGER: If loser mode has lost twice, stand up automatically!
    if selectedGameMode == "loser" and totalOpponentWins >= 2 and not hasLeftMatchThisGame then
        local character = localPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.SeatPart then
                hasLeftMatchThisGame = true
                humanoid.Jump = true -- Triggers character to break seat weld and jump out of match
                targetLabel.Text = "❌ Lost twice! Jumped out."
            end
        end
    end
end

-- ==========================================
-- 7. RUNTIME TICK CONTROL LOOP
-- ==========================================
RunService.Heartbeat:Connect(function()
    updateCurrentSeatLocation()
    syncRoundWinCircles() 
    
    local liveTime = getLiveTableTimerValue()
    local targetTime = getCleanTargetTime()
    
    if liveTime then
        physicalTimerLabel.Text = liveTime
    else
        physicalTimerLabel.Text = "00.00"
    end
    
    -- Reset tracker flags when you are completely standing or table resets entirely
    if liveTime == "00.00" or liveTime == "00.01" or tonumber(liveTime) == 0 or not currentStationFolder then
        hasClickedThisRound = false
        if not currentStationFolder then
            hasLeftMatchThisGame = false -- Reset auto-leave filter when you successfully walk away
        end
    end

    if autoClickEnabled and liveTime and liveTime ~= "00.00" then
        if selectedGameMode == "loser" then
            targetLabel.Text = "Mode: FORCED LOSS (SPAM)"
            if not hasClickedThisRound then
                spamClickTableButtonForLoss()
                hasClickedThisRound = true
            end
            
        elseif selectedGameMode == "winner" and targetTime then
            targetLabel.Text = "Mode: FORCED WIN (00.50)"
            if not hasClickedThisRound and liveTime == targetTime then
                hasClickedThisRound = true
                clickPhysicalTableButton()
            end
            
        elseif targetTime then
            targetLabel.Text = "Target Time Goal: " .. targetTime
            if not hasClickedThisRound and liveTime == targetTime then
                hasClickedThisRound = true
                clickPhysicalTableButton()
            end
        end
    else
        if selectedGameMode == "loser" then
            if hasLeftMatchThisGame then
                targetLabel.Text = "❌ Match Ended (Auto-Left)"
            else
                targetLabel.Text = "Mode: FORCED LOSS (SPAM)"
            end
        elseif selectedGameMode == "winner" then
            targetLabel.Text = "Mode: FORCED WIN (00.50)"
        else
            targetLabel.Text = "Waiting for active time goal..."
        end
    end
end)
