--// =========================================
--// AUTO SEAT SYSTEM
--// =========================================
local function getTargetSeat()
	local gs = Workspace:FindFirstChild("GameStations")
	if not gs then return nil end

	local normal = gs:FindFirstChild("Normal")
	if not normal then return nil end

	local station1 = normal:FindFirstChild("1")
	if not station1 then return nil end

	local chairs = station1:FindFirstChild("Chairs")
	if not chairs then return nil end

	local targetFolder

	if selectedGameMode == "winner" then
		targetFolder = chairs:FindFirstChild("Player1")
	elseif selectedGameMode == "loser" then
		targetFolder = chairs:FindFirstChild("Player2")
	end

	if targetFolder then
		return targetFolder:FindFirstChild("Seat")
	end

	return nil
end

--// =========================================
--// CURRENT TABLE DETECTION
--// =========================================
local function updateCurrentSeatLocation()

	local character = localPlayer.Character
	if not character then return end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local seat = humanoid.SeatPart
	if not seat then return end

	local gameStations = Workspace:FindFirstChild("GameStations")
	if not gameStations then return end

	for _, folder in ipairs({
		gameStations:FindFirstChild("Normal"),
		gameStations:FindFirstChild("Hard")
	}) do

		if folder then
			for _, station in ipairs(folder:GetChildren()) do

				local chairs = station:FindFirstChild("Chairs")

				if chairs then

					local p1 = chairs:FindFirstChild("Player1")
					local p2 = chairs:FindFirstChild("Player2")

					if p1 and (p1 == seat or p1:IsAncestorOf(seat)) then
						currentStationFolder = station
						currentSeatRole = "Player1"
						return
					end

					if p2 and (p2 == seat or p2:IsAncestorOf(seat)) then
						currentStationFolder = station
						currentSeatRole = "Player2"
						return
					end
				end
			end
		end
	end
end

--// =========================================
--// TIMER
--// =========================================
local function getLiveTableTimerValue()

	if not currentStationFolder then return nil end

	local timerModel = currentStationFolder:FindFirstChild("Timer")
	if not timerModel then return nil end

	local display = timerModel:FindFirstChild(currentSeatRole)

	if display and display:FindFirstChild("SurfaceGui") then

		local textLabel =
			display.SurfaceGui:FindFirstChildOfClass("TextLabel")
			or display.SurfaceGui:FindFirstChild("TimerText")

		if textLabel then
			return textLabel.Text
		end
	end

	return nil
end

local function getCleanTargetTime()

	if selectedGameMode == "winner" then
		return "00.50"
	end

	local gameUi = playerGui:FindFirstChild("GameUI")
	if not gameUi then return nil end

	local secondsToSet = gameUi:FindFirstChild("SecondsToSet")

	if secondsToSet and secondsToSet.Visible then
		local target = string.match(secondsToSet.Text, "%d+%.%d+")
		return target
	end

	return nil
end

